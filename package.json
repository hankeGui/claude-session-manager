{
  "name": "claude-session-mgr",
  "version": "1.0.4",
  "description": "Web UI for browsing, searching, resuming, and cleaning up Claude Code sessions",
  "main": "server.ts",
  "bin": {
    "claude-session-mgr": "./bin/cli.js",
    "csm": "./bin/cli.js"
  },
  "scripts": {
    "start": "tsx server.ts",
    "dev": "cd client && npm run dev",
    "build": "cd client && npm install && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "claude",
    "claude-code",
    "session-manager",
    "cli",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hankeGui/claude-session-manager.git"
  },
  "homepage": "https://github.com/hankeGui/claude-session-manager#readme",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "src/",
    "dist/",
    "server.ts",
    "tsconfig.json"
  ],
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "express": "^4.21.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
